generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatar    String?
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  teams     Team[]
  leagues   LeagueMember[]
  notifications Notification[]
  savedTeams SavedTeam[]
}

model League {
  id          String   @id @default(cuid())
  name        String
  description String?
  inviteCode  String   @unique @default(cuid())
  createdAt   DateTime @default(now())
  members     LeagueMember[]
}

model LeagueMember {
  id        String   @id @default(cuid())
  leagueId  String
  userId    String
  joinedAt  DateTime @default(now())

  league    League   @relation(references: [id], fields: [leagueId])
  user      User     @relation(references: [id], fields: [userId])

  @@unique([leagueId, userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String   @default("info") // info, position_change, score_update, deadline
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(references: [id], fields: [userId])
}

model Tournament {
  id          String   @id @default(cuid())
  name        String
  course      String?
  yardage     Int?
  architect   String?
  courseLocation String?
  startDate   DateTime
  endDate     DateTime
  status      String   @default("upcoming") // upcoming, entries_open, in_progress, completed
  par         Int      @default(72)
  cutLine     Int?
  entryFee    Int      @default(1500) // pence
  currentRound Int     @default(0) // 0=not started, 1-4 rounds, 5=completed
  prizePool   Int      @default(0) // total pence collected
  payoutStructure String? // JSON: [{position: 1, percentage: 50}, ...]
  category    String   @default("major") // major, signature, playoff, dpwt
  tour        String   @default("pga") // pga, dpwt
  createdAt   DateTime @default(now())
  players     TournamentPlayer[]
  teams       Team[]
  scores      Score[]
  messages    BroadcastMessage[]
  sideBets    SideBet[]
  sidePots    TournamentSidePot[]
}

model BroadcastMessage {
  id           String   @id @default(cuid())
  tournamentId String
  subject      String
  body         String
  createdAt    DateTime @default(now())

  tournament   Tournament @relation(references: [id], fields: [tournamentId])
}

enum Tier {
  T1_10
  T11_20
  T21_30
  T31_50
  T51_PLUS
}

model Player {
  id             String              @id @default(cuid())
  name           String
  country        String?
  dataGolfRank   Int?
  tour           String?             // "pga", "lpga", "dpwt"
  // Enrichment fields (from public data feeds)
  photoUrl       String?
  bio            String?             @db.Text
  dateOfBirth    DateTime?
  turnedPro      Int?
  heightCm       Int?
  weightKg       Int?
  college        String?
  birthplace     String?
  careerEarnings String?             // stored as string for display
  wtRank         Int?                // Official World Golf Ranking
  fedexRank      Int?
  enrichedAt     DateTime?
  createdAt      DateTime            @default(now())
  tournaments    TournamentPlayer[]
  scores         Score[]
  savedTeamSlots SavedTeamPlayer[]
}

model FeedStatus {
  id            String   @id @default(cuid())
  feedType      String   // "rankings", "results", "players", "photos", "schedule"
  feedSource    String   // "espn", "owgr", "datagolf", "wikipedia", "pga_tour"
  status        String   @default("idle") // idle, running, success, error
  lastRunAt     DateTime?
  nextRunAt     DateTime?
  recordsTotal  Int      @default(0)
  recordsSynced Int      @default(0)
  errorCount    Int      @default(0)
  lastError     String?  @db.Text
  lastMessage   String?  @db.Text
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TournamentPlayer {
  id           String    @id @default(cuid())
  tournamentId String
  playerId     String
  tier         String    // T1_10, T11_20, T21_30, T31_50, T51_PLUS
  selectionCount Int     @default(0)
  madeCut      Boolean?
  withdrew     Boolean   @default(false)

  tournament   Tournament @relation(references: [id], fields: [tournamentId])
  player       Player     @relation(references: [id], fields: [playerId])
  selections   TeamSelection[]

  @@unique([tournamentId, playerId])
}

model Team {
  id           String   @id @default(cuid())
  userId       String
  tournamentId String
  name         String   @default("My Team")
  paid         Boolean  @default(false)
  totalScore   Int      @default(0)
  position     Int?
  createdAt    DateTime @default(now())

  user         User       @relation(references: [id], fields: [userId])
  tournament   Tournament @relation(references: [id], fields: [tournamentId])
  selections   TeamSelection[]
  subLogs      TeamSubLog[]
}

model TeamSelection {
  id                  String   @id @default(cuid())
  teamId              String
  tournamentPlayerId  String

  team                Team             @relation(references: [id], fields: [teamId])
  tournamentPlayer    TournamentPlayer @relation(references: [id], fields: [tournamentPlayerId])

  @@unique([teamId, tournamentPlayerId])
}

model Score {
  id             String   @id @default(cuid())
  tournamentId   String
  playerId       String
  round          Int      // 1, 2, 3, 4
  strokes        Int?
  isEstimated    Boolean  @default(false) // true if calculated from cut average
  updatedAt      DateTime @updatedAt

  tournament     Tournament @relation(references: [id], fields: [tournamentId])
  player         Player     @relation(references: [id], fields: [playerId])

  @@unique([tournamentId, playerId, round])
}

model SideBet {
  id           String   @id @default(cuid())
  tournamentId String
  userId       String
  type         String   // "top_golfer", "best_round", "dark_horse"
  playerId     String?  // for top_golfer: which player they back
  roundNumber  Int?     // for best_round: which round
  paid         Boolean  @default(false)
  createdAt    DateTime @default(now())

  tournament   Tournament @relation(references: [id], fields: [tournamentId])
}

model TournamentSidePot {
  id           String   @id @default(cuid())
  tournamentId String
  type         String   // "top_golfer", "best_round", "dark_horse"
  entryFee     Int      @default(500) // £5 per side bet
  description  String
  active       Boolean  @default(true)

  tournament   Tournament @relation(references: [id], fields: [tournamentId])
}

// ===== Saved Team Templates =====
// Stores reusable team templates (5 players, one per tier)
// Not tied to any tournament — applied when entering events

model SavedTeam {
  id        String   @id @default(cuid())
  userId    String
  name      String   @default("My Squad")
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(references: [id], fields: [userId])
  players   SavedTeamPlayer[]

  @@index([userId])
}

model SavedTeamPlayer {
  id           String @id @default(cuid())
  savedTeamId  String
  playerId     String
  tier         String   // T1_10, T11_20, T21_30, T31_50, T51_PLUS

  savedTeam    SavedTeam @relation(references: [id], fields: [savedTeamId], onDelete: Cascade)
  player       Player    @relation(references: [id], fields: [playerId])

  @@unique([savedTeamId, playerId])
  @@index([savedTeamId])
}

// ===== Auto-Sub Log =====
// Tracks automatic player replacements when a WD is detected

model TeamSubLog {
  id            String   @id @default(cuid())
  teamId        String
  oldPlayerId   String
  newPlayerId   String
  tier          String
  reason        String   // "pre_round_wd", "no_show", "dns"
  createdAt     DateTime @default(now())

  team          Team     @relation(references: [id], fields: [teamId])
}

// ===== Target Challenge private judging pilot =====
// These records are deliberately separate from customer entries and payments.

model TargetJudgingRound {
  id                  String                  @id @default(cuid())
  slug                String                  @unique
  name                String
  scenarioVersion     String
  scenarioHash        String
  status              String                  @default("DRAFT")
  panelMode           String                  @default("OFFICIAL")
  createdByEmail      String
  officialTargets     Json?
  officialTargetsHash String?
  calculatedAt        DateTime?
  pilotEntriesSealedAt DateTime?
  pilotEntrySetHash    String?
  pilotEntryCount      Int?
  pilotResults         Json?
  pilotResultsHash     String?
  pilotScoredAt        DateTime?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  assignments         TargetJudgeAssignment[]
  auditEvents         TargetJudgeAudit[]
  pilotEntries        TargetPilotEntry[]
}

model TargetPilotEntry {
  id             String             @id @default(cuid())
  roundId        String
  email          String
  submission     Json
  submissionHash String
  submittedAt    DateTime           @default(now())
  round          TargetJudgingRound @relation(references: [id], fields: [roundId], onDelete: Cascade)

  @@unique([roundId, email])
  @@index([roundId, submittedAt])
}

model TargetJudgeAssignment {
  id                     String              @id @default(cuid())
  roundId                String
  email                  String
  displayName            String
  credential             String
  seat                    Int
  declarationConfirmedAt DateTime?
  initialSubmission      Json?
  initialLockedAt        DateTime?
  finalSubmission        Json?
  finalLockedAt          DateTime?
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  round                  TargetJudgingRound  @relation(references: [id], fields: [roundId], onDelete: Cascade)

  @@unique([roundId, email])
  @@unique([roundId, seat])
  @@index([email])
}

model TargetJudgeAudit {
  id         String             @id @default(cuid())
  roundId    String
  actorEmail String
  action     String
  payload    Json?
  createdAt  DateTime           @default(now())
  round      TargetJudgingRound @relation(references: [id], fields: [roundId], onDelete: Cascade)

  @@index([roundId, createdAt])
}

// ===== Rocket Classic open-registration test flight =====
// Test passes are account-bound entitlements, not payments or cash-value vouchers.

model RocketBetaCampaign {
  id              String             @id @default(cuid())
  slug            String             @unique
  name            String
  tournamentId    String             @unique
  targetRoundId   String             @unique
  status          String             @default("OPEN")
  entryOpensAt    DateTime?
  entryClosesAt   DateTime?
  fieldVersion    String?
  fieldHash       String?
  fieldFrozenAt   DateTime?
  results         Json?
  resultsHash     String?
  finalizedAt     DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  members         RocketBetaMember[]
  passes          RocketBetaPass[]
  auditEvents     RocketBetaAudit[]
}

model RocketBetaMember {
  id          String             @id @default(cuid())
  campaignId  String
  email       String
  userId      String?
  displayName String?
  active      Boolean            @default(true)
  invitedAt   DateTime           @default(now())
  acceptedAt  DateTime?
  campaign    RocketBetaCampaign @relation(references: [id], fields: [campaignId], onDelete: Cascade)
  passes      RocketBetaPass[]

  @@unique([campaignId, email])
  @@unique([campaignId, userId])
  @@index([email])
}

model RocketBetaPass {
  id                  String             @id @default(cuid())
  campaignId          String
  memberId            String
  userId              String
  sourceTargetEntryId String             @unique
  status              String             @default("UNLOCKED")
  unlockedAt          DateTime           @default(now())
  redeemedAt          DateTime?
  teamId              String?            @unique
  campaign            RocketBetaCampaign @relation(references: [id], fields: [campaignId], onDelete: Cascade)
  member              RocketBetaMember   @relation(references: [id], fields: [memberId], onDelete: Cascade)

  @@unique([campaignId, userId])
  @@index([userId])
}

model RocketBetaAudit {
  id          String             @id @default(cuid())
  campaignId  String
  actorUserId String?
  actorEmail  String?
  action      String
  payload     Json?
  createdAt   DateTime           @default(now())
  campaign    RocketBetaCampaign @relation(references: [id], fields: [campaignId], onDelete: Cascade)

  @@index([campaignId, createdAt])
}
